{
  "version": 2,
  "buildCommand": "pnpm build",
  "functions": {
    "dist/vercel.js": {
      "maxDuration": 30,
      "includeFiles": "{dist,public}/**"
    }
  },
  "rewrites": [
    { "source": "/(.*)", "destination": "/dist/vercel.js" }
  ],
  "env": {
    "ALLOWED_DOMAIN": "*",
    "DISALLOW_ROBOT": "true",
    "CACHE_TTL": "3600",
    "REQUEST_TIMEOUT": "6000",
    "USE_LOG_FILE": "false",
    "RSS_MODE": "false"
  }
}
